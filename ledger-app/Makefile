# =============================================================================
# Octra Wallet Ledger App - Makefile
# Production build for Nano S, Nano X, and Stax
# Copyright 2025-2026 Octra Labs
# =============================================================================

# Application info
APPNAME    = "Octra"
APPVERSION = "1.0.0"

# Source files (glyphs are auto-generated by SDK from icons/ directory)
SOURCE_FILES  = src/main.c

# Include paths
INCLUDES_PATH += $(CURDIR)/src
INCLUDES_PATH += $(CURDIR)/include

# Required SDK definitions
DEFINES += IO_HID_EP_LENGTH=64
DEFINES += USB_SEGMENT_SIZE=64

# Disable debug output (set DEBUG=1 to enable)
DEBUG = 0

# Use clang (required by SDK)
CC = clang

# Compiler flags
CFLAGS += -O2 -Wall -Wextra -Wno-unused-parameter
CFLAGS += -Wno-unused-variable -Wno-unused-function

# =============================================================================
# SDK Build System
# Use Makefile.standard_app which correctly sets up HAVE_UX_FLOW,
# OS_IO_SEPROXYHAL, and all other required defines.
# =============================================================================

include $(BOLOS_SDK)/Makefile.standard_app

# =============================================================================
# Build Targets
# =============================================================================

# Default target - SDK provides the 'all' target via Makefile.standard_app
# We override the post-build message here.
.PHONY: post_build
post_build:
	@echo ""
	@echo "=========================================="
	@echo "  Octra Wallet - Build Complete"
	@echo "=========================================="
	@echo "  Target: $(TARGET_NAME)"
	@echo "  Output: $(TARGET_BUILD_DIR)/app.hex"
	@SIZE=$$(stat -c%s $(TARGET_BUILD_DIR)/app.hex 2>/dev/null || stat -f%z $(TARGET_BUILD_DIR)/app.hex); \
	echo "  Size:   $$SIZE bytes"; \
	if [ "$(TARGET_NAME)" = "TARGET_NANOS" ]; then \
		MAX=184320; echo "  Limit:  180 KB (Nano S)"; \
	elif [ "$(TARGET_NAME)" = "TARGET_NANOX" ]; then \
		MAX=409600; echo "  Limit:  400 KB (Nano X)"; \
	else \
		MAX=1572864; echo "  Limit:  1.5 MB (Stax)"; \
	fi; \
	if [ "$$SIZE" -gt "$$MAX" ]; then \
		echo "  ERROR: Size exceeds limit!"; \
		exit 1; \
	else \
		echo "  Status: OK"; \
	fi
	@echo ""

# =============================================================================
# Load to Device
# =============================================================================

load: $(TARGET_BUILD_DIR)/app.hex
	@echo ""
	@echo "Loading to device..."
	@echo ""
	python3 -m ledgerblue.loadApp \
		--targetId $(TARGET_ID) \
		--fileName $(TARGET_BUILD_DIR)/app.hex \
		--appFlags 0x00 \
		--appName $(APPNAME) \
		--appVersion $(APPVERSION) \
		--appPath "/" \
		--tlv \
		--offline
	@echo ""
	@echo "App loaded successfully!"
	@echo ""

# Delete from device
delete:
	@echo "Deleting app from device..."
	python3 -m ledgerblue.deleteApp --appName $(APPNAME)
	@echo "Done."

# =============================================================================
# Help
# =============================================================================

help:
	@echo ""
	@echo "Octra Wallet Ledger App - Build System"
	@echo "======================================="
	@echo ""
	@echo "Usage:"
	@echo "  make          - Build for current target (set via BOLOS_SDK)"
	@echo "  make load     - Load app to connected device"
	@echo "  make delete   - Delete app from device"
	@echo "  make clean    - Clean build artifacts"
	@echo ""
	@echo "Docker Build (Recommended):"
	@echo ""
	@echo "  # Nano S"
	@echo "  docker run --rm -e BOLOS_SDK=/opt/nanos-secure-sdk \\"
	@echo "    -v \$$(pwd):/app -w /app \\"
	@echo "    ghcr.io/ledgerhq/ledger-app-builder/ledger-app-builder-lite:latest make"
	@echo ""
	@echo "  # Nano X"
	@echo "  docker run --rm -e BOLOS_SDK=/opt/nanox-secure-sdk \\"
	@echo "    -v \$$(pwd):/app -w /app \\"
	@echo "    ghcr.io/ledgerhq/ledger-app-builder/ledger-app-builder-lite:latest make"
	@echo ""
	@echo "  # Nano S Plus"
	@echo "  docker run --rm -e BOLOS_SDK=/opt/nanosplus-secure-sdk \\"
	@echo "    -v \$$(pwd):/app -w /app \\"
	@echo "    ghcr.io/ledgerhq/ledger-app-builder/ledger-app-builder-lite:latest make"
	@echo ""
	@echo "Size Limits:"
	@echo "  Nano S:       180 KB (184,320 bytes)"
	@echo "  Nano S Plus:  180 KB (184,320 bytes)"
	@echo "  Nano X:       400 KB (409,600 bytes)"
	@echo "  Stax:         1.5 MB (1,572,864 bytes)"
	@echo ""

.PHONY: load delete help post_build
